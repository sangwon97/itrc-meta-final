# ITRC 백엔드 Strapi API URL
VITE_API_URL=http://localhost:1337

# 정적 자산(models / videos / npc) CDN base URL. 빈 값이면 로컬 상대경로 사용.
# 프로덕션 예: https://ajnrcqijhiaz29099267.gcdn.ntruss.com
VITE_CDN_URL=

# OpenAI API key
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Express server port (default: 3001)
PORT=3001

# Allowed CORS origin (default: http://localhost:5173)
CLIENT_ORIGIN=http://localhost:5173
